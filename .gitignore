/target
**/*.rs.bk
.DS_Store

# local secrets — never commit, never read into agent context
.env
.env.*
!.env.example
*.p12
*.pem
*.mobileprovision
*.cer
*.key
keys/
certs/

# nix
.direnv/

# whisper model blobs (downloaded by shell/spike, never committed)
*.bin
spikes/whisper-ios/models/

# iOS build artifacts
apps/ios/build/
apps/ios/DerivedData/
apps/ios/*.xcodeproj/
# The generated uniffi Swift bindings (Packages/*/Sources/**/*.swift) ARE
# committed — they match the checked-in Rust surface and are regenerated by
# build-ffi.sh. Only the large xcframework binaries are ignored (below, plus the
# per-package rule in apps/ios/.gitignore).
apps/ios/Packages/*/*.xcframework/
apps/ios/Packages/*/Frameworks/*.xcframework/
apps/ios/project.local.yml

# simulator/QA capture evidence
/screenshots/

# evals example output
report.json

# lived-in demo seed — generated from private ~/athanor material at runtime.
# The DATA (SQLite db) is NEVER committed; only the translation script is
# (which lives in crates/athanor-cli/src/seed/ — a SOURCE dir, NOT matched
# here). Patterns target the generated artifact by anchored path and by
# extension (see docs/research/lived-seed-mapping.md).
/seeds/
*.seed.sqlite
*.seed.db
*.seed.sqlite-journal
lived-seed.sqlite
lived-seed.sqlite-journal
lived-seed.db
athanor-seed.*
